				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-23T16:35:56.149623+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "L2et5V0SRlGwoa7AJgyZ/A=="
				},
				"code" : "slide := GtProtoLiveSlide new paragraph\r\t\tsubtitleWithFormat: (PrioritySlideshow new asSubtitle: 'A bullet list');\r\t\tparagraphWithFormat: (PrioritySlideshow new\r\t\t\t\tasText: '• Bullet 1\r• Bullet 2\r• Bullet 3')."
			},
